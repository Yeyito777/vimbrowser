#!/usr/bin/env python3
import os
import socket
import sys
from pathlib import Path


def default_socket_path() -> Path:
    state_home = os.environ.get("XDG_STATE_HOME")
    if state_home:
        return Path(state_home) / "vimbrowser" / "ipc.sock"
    home = os.environ.get("HOME")
    if home:
        return Path(home) / ".local" / "state" / "vimbrowser" / "ipc.sock"
    return Path("/tmp/vimbrowser/ipc.sock")


def main() -> int:
    socket_path = Path(os.environ.get("VIMBROWSER_IPC", default_socket_path()))
    if len(sys.argv) < 2:
        command = "status"
    else:
        command = " ".join(sys.argv[1:])

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
        sock.connect(str(socket_path))
        sock.sendall((command + "\n").encode())
        sock.shutdown(socket.SHUT_WR)
        chunks = []
        while True:
            data = sock.recv(4096)
            if not data:
                break
            chunks.append(data)
    sys.stdout.buffer.write(b"".join(chunks))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
