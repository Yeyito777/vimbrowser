{
  // WebContentsDiscard works around an issue with legacy discarding
  // on ChromeOS that causes webdriver to lock up.
  flags: --request-desktop-sites --allow-background-interventions --enable-features=BackgroundNotPerceptibleBinding,WebContentsDiscard,ChangeUnfocusedPriority,ProcessRankPolicyAndroid,ProtectedTabsAndroid,SubframePriorityContribution,SubframeImportance $[CHROME_FLAGS]
}
