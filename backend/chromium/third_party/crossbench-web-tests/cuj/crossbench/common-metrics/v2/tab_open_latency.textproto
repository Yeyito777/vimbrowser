query: {
  id: "tab_open_latency_output_query"
  table {
    table_name: "tab_open_latency_output"
    module_name: "sql_packages.queries.tab_open_latency"
    column_names: "it_id"
    column_names: "id"
    column_names: "open_latency"
  }
}

metric_spec: {
  id: "no-crosbolt.cuj.common-metrics.tab_open_latency_by_tab"
  dimensions: "it_id"
  dimensions: "id"
  value: "open_latency"
  query: {
    inner_query_id: "tab_open_latency_output_query"
  }
}

metric_spec: {
  id: "cuj.common-metrics.tab_open_latency"
  dimensions: "it_id"
  value: "open_latency"
  query: {
    inner_query_id: "tab_open_latency_output_query"
  }
}
