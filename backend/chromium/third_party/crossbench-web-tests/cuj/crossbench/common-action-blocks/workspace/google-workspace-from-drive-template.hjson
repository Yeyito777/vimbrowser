{
  pages: {
    WorkspaceWorkflow: {
      login: google
      blocks: {
        setup: $[SETUP_ACTIONS]
        copy-doc: {
          template: ./copy-doc-from-drive.hjson
          args: {}
          unbound_args: [
            CLICK_INPUT_SOURCE
            DOC_APP
            DOC_NAME
            DRIVE_FOLDER_URL
          ]
        }
        comment: ./make-comment.hjson
        scroll: ../basic/scroll.hjson
        cleanup: ./cleanup-doc.hjson
      }
    }
  }
}
