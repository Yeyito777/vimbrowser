{
  template: ./play-video.hjson
  unbound_args: [
    UNMUTE_PLAYER
    FILE_NAME
  ]
  args: {
    ADDITIONAL_ACTIONS: [
      {
        action: probe
        probe: video_acceleration
        kwargs: {
          expect_hw_accel: $[EXPECT_HW_ACCEL]
        }
      }
    ]
  }
}
