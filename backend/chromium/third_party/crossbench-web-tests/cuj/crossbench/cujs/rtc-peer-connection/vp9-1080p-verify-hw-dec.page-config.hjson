{
  template: ./action-blocks/rtc.hjson
  args: {
    CODEC_PROFILE: VP9
    RTC_STREAM_WIDTH: 1920
    RTC_STREAM_HEIGHT: 1080
    SVC_MODE: ""
    SIMULCASTS: 1
    DISPLAY_MEDIA_TYPE: ""
    VERIFY_HW_ENCODE: "false"
    VERIFY_HW_DECODE: "true"
  }
}
