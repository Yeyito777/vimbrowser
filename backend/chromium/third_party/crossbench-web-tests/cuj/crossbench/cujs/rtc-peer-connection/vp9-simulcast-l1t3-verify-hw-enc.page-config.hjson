{
  template: ./action-blocks/rtc.hjson
  args: {
    CODEC_PROFILE: VP9
    RTC_STREAM_WIDTH: 1280
    RTC_STREAM_HEIGHT: 720
    SVC_MODE: L1T3
    SIMULCASTS: 3
    DISPLAY_MEDIA_TYPE: ""
    VERIFY_HW_ENCODE: "true"
    VERIFY_HW_DECODE: "false"
  }
}
