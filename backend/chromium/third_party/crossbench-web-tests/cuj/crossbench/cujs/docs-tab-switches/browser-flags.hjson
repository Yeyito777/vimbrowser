{
  template: ../../browser-flags/common-flags.hjson
  args: {
    CHROME_FLAGS: --autoplay-policy=no-user-gesture-required --disable-field-trial-config --enable-benchmarking --enable-features=Canvas2DHibernation,EvictionUnlocksResources,ClearCanvasResourcesInBackground,Canvas2DHibernationReleaseTransferMemory,CanvasHibernationSnapshotZstd
  }
}
