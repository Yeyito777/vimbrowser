{
  actions: [
    {
      action: js
      script: performance.mark('navigate_to_tab')
    }
    {
      action: switch_tab
      tab_index: $[TAB_INDEX]
    }
    {
      action: js
      script: performance.mark('navigate_to_tab_done')
    }
    {
      action: wait
      duration: 500ms
    }
  ]
}
