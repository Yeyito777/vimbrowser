{
  page-load: {
    template: ../../../common-action-blocks/basic/page-load.hjson
    args: {
      READY_STATE: complete
      PAGE_LOAD_TIMEOUT: 2m
    }
    unbound_args: [
      PAGE_URL
      TARGET
    ]
  }
  scroll-page: {
    actions: [
      {
        action: js
        script: performance.mark('scroll-page-start');
      }
      {
        action: scroll
        distance: 640
        duration: 200ms
        source: touch
      }
      // To prevent the page elements from being unstable after operation,
      // which will affect some subsequent operations, a short wait is added here
      {
        action: wait
        duration: 2s
      }
    ]
  }
}
