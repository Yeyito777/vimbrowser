{
  template: ./base-template.hjson
  args: {
    SCREEN_SETTINGS: [
      {
        action: click
        source: touch
        pos: {
          selector: "[data-e2e='more-menu-icon']"
          wait: true
        }
        verify: "[data-e2e='more-menu-popover_full-screen']"
      }
      // Wait for menu animation to finish
      {
        action: wait
        duration: 1s
      }
      {
        action: click
        source: touch
        pos: {
          selector: "[data-e2e='more-menu-popover_full-screen']"
          wait: true
        }
        verify: ":fullscreen"
      }
    ]
  }
  unbound_args: [
    PAGE_URL
    PLAYBACK_DURATION
  ]
}
