{
  "pages-$[INDEX_PREFIX]0": {
    template: ./open-tab.hjson
    args: {
      TAB_INDEX: $[INDEX_PREFIX]0
    }
    unbound_args: [
      MEMORY_GB
      INDEX_PREFIX
    ]
  }
