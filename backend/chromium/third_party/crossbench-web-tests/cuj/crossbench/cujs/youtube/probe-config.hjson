{
  template: ../../probe-config.hjson
  args: {
    TRACE_PROCESSOR_QUERIES: [
      {
        name: Playback Stats
        sql:
          '''
            INCLUDE PERFETTO MODULE
                sql_packages.video_streaming.streaming_playback_stats;
            SELECT * FROM streaming_stats_output;
          '''
      }
    ]
    METRIC_DEFINITIONS: [
      ../../common-metrics/v2/streaming_playback_stats.textproto
    ]
    TRACE_CONFIG: ../../trace-config/detailed-trace-config.pbtxt
    ADDITIONAL_PROBES: []
  }
}
