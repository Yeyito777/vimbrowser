{
  actions: [
    {
      action: get
      url: $[URL]
      target: $[TARGET]
      ready_state: complete
      timeout: 2m
    }
    {
      action: close_tab
    }
    {
      action: meminfo
      system: true
      title: closed
    }
  ]
  teardown: [
    {
      action: probe
      probe: dump_heap
      kwargs: {
        type: java
      }
    }
  ]
}
