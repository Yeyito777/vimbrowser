{
  "probes": {
    "trace_processor": {
      "queries": [
        "powerline_cpu_rails"
      ]
    }
    "perfetto": {
      "trace_browser_startup": false
      "textproto":
        '''
          buffers {
            size_kb: 524288
            fill_policy: RING_BUFFER
          }
          buffers {
            size_kb: 8192
            fill_policy: RING_BUFFER
          }
          data_sources {
            config {
              name: "track_event"
              track_event_config {
                disabled_categories: "*"
                enabled_categories: "audio"
                enabled_categories: "media"
                enabled_categories: "media_router"
                enabled_categories: "toplevel"
                enabled_categories: "toplevel.flow"
                enabled_categories: "scheduler"
                enabled_categories: "sequence_manager"
                enabled_categories: "disabled-by-default-toplevel.flow"
                enabled_categories: "base"
                enabled_categories: "disabled-by-default-audio"
                enabled_categories: "webaudio"
                enabled_categories: "disabled-by-default-webaudio"
                enabled_categories: "webaudio.audionode"
                enabled_categories: "disabled-by-default-webaudio.audionode"
                enabled_categories: "webrtc"
                enabled_categories: "disabled-by-default-webrtc"
                enabled_categories: "audio-worklet"
                enabled_categories: "disabled-by-default-audio-worklet"
                enabled_categories: "mediastream"
                enabled_categories: "disabled-by-default-mediastream"
                enabled_categories: "v8.gc"
                enabled_categories: "disabled-by-default-v8.gc"
                enabled_categories: "disabled-by-default-toplevel"
                enabled_categories: "wakeup.flow"
                enabled_categories: "disabled-by-default-wakeup.flow"
                enabled_categories: "cpu_profiler"
                enabled_categories: "disabled-by-default-cpu_profiler"
                enabled_categories: "disabled-by-default-scheduler"
                enabled_categories: "p2p"
                enabled_categories: "disabled-by-default-p2p"
                enabled_categories: "net"
                enabled_categories: "disabled-by-default-net"
                enabled_categories: "gpu"
                enabled_categories: "gpu.capture"
                enabled_categories: "disabled-by-default-video_and_image_capture"
                enabled_categories: "__metadata"
                timestamp_unit_multiplier: 1000
                filter_debug_annotations: false
                enable_thread_time_sampling: true
                filter_dynamic_event_names: false
              }
            }
          }
          data_sources {
            config {
              name: "org.chromium.trace_metadata2"
            }
          }
          data_sources {
            config {
              name: "org.chromium.sampler_profiler"
            }
          }
          data_sources {
            config {
              name: "linux.ftrace"
              ftrace_config {
                ftrace_events: "sched/sched_process_exit"
                ftrace_events: "sched/sched_process_free"
                ftrace_events: "task/task_newtask"
                ftrace_events: "task/task_rename"
                ftrace_events: "power/cpu_frequency"
                ftrace_events: "power/cpu_idle"
                ftrace_events: "power/suspend_resume"
              }
            }
          }
          data_sources {
            config {
              name: "linux.process_stats"
              process_stats_config {
                scan_all_processes_on_start: true
              }
            }
          }
          data_sources {
            config {
              name: "linux.sys_stats"
              sys_stats_config {
                stat_period_ms: 1000
                stat_counters: STAT_CPU_TIMES
                stat_counters: STAT_FORK_COUNT
                cpufreq_period_ms: 1000
              }
            }
          }
          data_sources {
            config {
              name: "android.power"
              android_power_config {
                battery_poll_ms: 1000
                battery_counters: BATTERY_COUNTER_CAPACITY_PERCENT
                battery_counters: BATTERY_COUNTER_CHARGE
                battery_counters: BATTERY_COUNTER_CURRENT
                collect_power_rails: true
              }
            }
          }
          duration_ms: 60000
          write_into_file: true
          file_write_period_ms: 5000
          max_file_size_bytes: 500000000
        '''
    }
  }
}
