{
  "pages": {
    "amazon_product": [
      {
        "action": "get"
        "url": "about:blank"
        "target": "_new_tab"
      }
      {
        "action": "wait"
        "duration": "1s"
      }
      {
        "action": "probe"
        "probe": "js"
        "kwargs": {
          "js":
            '''
            const mark = performance.mark('LoadLine2/amazon_product/start');
            const navigationStart = performance.timeOrigin + mark.startTime;
            window.location.href = 'https://www.amazon.co.uk/NIVEA-Suncream-Spray-Protect-Moisture/dp/B001B0OJXM';
            return {'amazonNavigation': navigationStart};
            '''
        }
      }
      {
        "action": "wait_for_condition"
        "condition":
          '''
          return performance.getEntriesByName('LoadLine2/amazon_product/interactive_raf').length > 0
              && performance.getEntriesByName('LoadLine2/amazon_product/visual_raf').length > 0
          '''
        "timeout": "10s"
      }
      {
        "action": "wait"
        "duration": "100ms"
      }
      {
        "action": "probe"
        "probe": "js"
        "kwargs": {
          "js":
            '''
            performance.mark('LoadLine2/amazon_product/finish');
            const visual = performance.timeOrigin +
                performance.getEntriesByName('LoadLine2/amazon_product/visual_raf')[0].startTime;
            const interactive = performance.timeOrigin +
                performance.getEntriesByName('LoadLine2/amazon_product/interactive_raf')[0].startTime;
            return {
            'amazonVisual': visual,
            'amazonInteractive': interactive,
            };
            '''
        }
      }
    ]
